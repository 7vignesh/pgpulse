# ---------------------------------------------------------------------------
# PgPulse environment configuration
# Copy to `.env` and adjust as needed. Never commit your real `.env`.
# ---------------------------------------------------------------------------

# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Write path: app -> PgBouncer (transaction mode) -> Postgres primary
# PgBouncer listens on 6432. Inside docker-compose the host is `pgbouncer`.
# ---------------------------------------------------------------------------
PRIMARY_DATABASE_URL=postgres://pgpulse:pgpulse_secret@pgbouncer:6432/pgpulse

# ---------------------------------------------------------------------------
# Read path: analytics queries -> read replica (direct, no PgBouncer needed,
# but you may point this at a second PgBouncer in production).
# Falls back to primary if replica is unavailable.
# ---------------------------------------------------------------------------
REPLICA_DATABASE_URL=postgres://pgpulse:pgpulse_secret@postgres-replica:5432/pgpulse

# ---------------------------------------------------------------------------
# Direct (no-PgBouncer) connection used by the migration runner and any DDL.
# Migrations must run on a direct session-mode connection because PgBouncer
# transaction mode does not support multi-statement DDL transactions, CREATE
# INDEX CONCURRENTLY, or session-level state.
# ---------------------------------------------------------------------------
ADMIN_DATABASE_URL=postgres://pgpulse:pgpulse_secret@postgres:5432/pgpulse

# Pool sizing (app-side pool to PgBouncer). PgBouncer multiplexes onto the
# small server-side pool, so this can be generous on the client side.
PG_POOL_MAX=20
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECT_TIMEOUT_MS=5000

# Rate limiting (per tenant, per window)
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=1 minute

# Postgres superuser bootstrap (used by docker entrypoint only)
POSTGRES_USER=pgpulse
POSTGRES_PASSWORD=pgpulse_secret
POSTGRES_DB=pgpulse

# Replication credentials (streaming replica)
REPLICATION_USER=replicator
REPLICATION_PASSWORD=replicator_secret
