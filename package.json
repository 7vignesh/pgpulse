{
  "name": "pgpulse",
  "version": "1.0.0",
  "description": "Production-grade multi-tenant API analytics platform built on PostgreSQL 16",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "migrate": "tsx src/db/migrate.ts up",
    "migrate:status": "tsx src/db/migrate.ts status",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/rate-limit": "9.1.0",
    "fastify": "4.28.1",
    "pg": "8.12.0",
    "pg-copy-streams": "6.0.6"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/pg": "8.11.6",
    "@types/pg-copy-streams": "1.2.5",
    "supertest": "7.0.0",
    "@types/supertest": "6.0.2",
    "tsx": "4.16.2",
    "typescript": "5.5.3",
    "vitest": "1.6.0"
  },
  "license": "MIT",
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
